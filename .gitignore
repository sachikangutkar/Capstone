# =============================================================================
# FarmAssist AI - .gitignore
# =============================================================================

# Environment Variables (NEVER commit API keys!)
.env
.env.*
*.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST

# Virtual Environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# IDE & Editor Files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Docker
*.dockerignore

# GCP / Cloud
.gcloud/
*.json
!package.json

# Testing & Coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml

# Jupyter Notebooks (if any)
.ipynb_checkpoints/

# Static uploads (user-uploaded crop images at runtime)
static/uploads/
